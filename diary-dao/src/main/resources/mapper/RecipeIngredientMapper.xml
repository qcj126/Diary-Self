<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="diary.dao.mapper.recipe.RecipeIngredientMapper">

    <resultMap id="BaseResultMap" type="diary.common.entity.recipe.po.RecipeIngredientPO">
        <id column="ingredient_id" property="ingredientId"/>
        <result column="recipe_id" property="recipeId"/>
        <result column="name" property="name"/>
        <result column="quantity" property="quantity"/>
        <result column="is_main" property="isMain"/>
        <result column="sort_order" property="sortOrder"/>
    </resultMap>

    <sql id="BaseColumns">
        ingredient_id, recipe_id, name, quantity, is_main, sort_order
    </sql>

    <!-- 批量插入 -->
    <insert id="batchInsert">
        INSERT INTO recipe_ingredient (ingredient_id, recipe_id, name, quantity, is_main, sort_order)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.ingredientId}, #{item.recipeId}, #{item.name},
            #{item.quantity}, #{item.isMain}, #{item.sortOrder})
        </foreach>
    </insert>

    <!-- 根据食谱ID查询 -->
    <select id="selectByRecipeId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM recipe_ingredient
        WHERE recipe_id = #{recipeId}
        ORDER BY sort_order ASC
    </select>

    <!-- 根据食谱ID列表批量查询 -->
    <select id="selectByRecipeIds" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM recipe_ingredient
        WHERE recipe_id IN
        <foreach collection="recipeIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY recipe_id, sort_order ASC
    </select>

    <!-- 根据食谱ID删除 -->
    <delete id="deleteByRecipeId">
        DELETE FROM recipe_ingredient
        WHERE recipe_id = #{recipeId}
    </delete>

    <!-- 根据ID列表删除 -->
    <delete id="deleteByIds">
        DELETE FROM recipe_ingredient
        WHERE ingredient_id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>