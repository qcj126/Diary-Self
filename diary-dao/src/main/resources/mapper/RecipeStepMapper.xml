<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="diary.dao.mapper.recipe.RecipeStepMapper">

    <resultMap id="BaseResultMap" type="diary.common.entity.recipe.po.RecipeStepPO">
        <id column="step_id" property="stepId"/>
        <result column="recipe_id" property="recipeId"/>
        <result column="step_number" property="stepNumber"/>
        <result column="description" property="description"/>
        <result column="image_url" property="imageUrl"/>
        <result column="timer_min" property="timerMin"/>
        <result column="sort_order" property="sortOrder"/>
    </resultMap>

    <sql id="BaseColumns">
        step_id, recipe_id, step_number, description, image_url, timer_min, sort_order
    </sql>

    <!-- 批量插入 -->
    <insert id="batchInsert">
        INSERT INTO recipe_step (step_id, recipe_id, step_number, description, image_url, timer_min, sort_order)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.stepId}, #{item.recipeId}, #{item.stepNumber}, #{item.description},
            #{item.imageUrl}, #{item.timerMin}, #{item.sortOrder})
        </foreach>
    </insert>

    <!-- 根据食谱ID查询 -->
    <select id="selectByRecipeId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM recipe_step
        WHERE recipe_id = #{recipeId}
        ORDER BY sort_order ASC
    </select>

    <!-- 根据食谱ID列表批量查询 -->
    <select id="selectByRecipeIds" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM recipe_step
        WHERE recipe_id IN
        <foreach collection="recipeIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY recipe_id, sort_order ASC
    </select>

    <!-- 根据食谱ID删除 -->
    <delete id="deleteByRecipeId">
        DELETE FROM recipe_step
        WHERE recipe_id = #{recipeId}
    </delete>

    <!-- 根据ID列表删除 -->
    <delete id="deleteByIds">
        DELETE FROM recipe_step
        WHERE step_id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>