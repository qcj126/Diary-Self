<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="diary.file.mapper.ImageMapper">
    <select id="selectImagesByIds" resultType="diary.common.entity.image.po.ImagePO">
        SELECT id, url FROM image WHERE id IN
        <foreach item="id" collection="imageIds" separator="," open="(" close=")">
            #{id}
        </foreach>
        and deleted = 0 and status = 1000
    </select>

    <update id="updateImageStatusById">

    </update>

    <select id="selectImageByTypeAndName" resultType="java.lang.Integer">

    </select>

    <insert id="batchAddImageToDb">

    </insert>
</mapper>
