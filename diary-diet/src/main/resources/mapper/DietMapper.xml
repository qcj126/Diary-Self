<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="diary.diarydiet.mapper.DietMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="diary.common.entity.diet.po.DietRecordPO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="eat_time" property="eatTime"/>
        <result column="meal_type" property="mealType"/>
        <result column="food_name" property="foodName"/>
        <result column="calories" property="calories"/>
        <result column="protein" property="protein"/>
        <result column="fat" property="fat"/>
        <result column="carbohydrate" property="carbohydrate"/>
        <result column="fullness_score" property="fullnessScore"/>
        <result column="location" property="location"/>
        <result column="note" property="note"/>
        <result column="deleted" property="deleted"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- 基础字段 -->
    <sql id="BaseColumns">
        id, user_id, eat_time, meal_type, food_name, calories,
        protein, fat, carbohydrate, fullness_score, location, note,
        deleted, created_at, updated_at
    </sql>

    <!-- 插入饮食记录 -->
    <insert id="insert" parameterType="diary.common.entity.diet.po.DietRecordPO">
        INSERT INTO diet_record (
            id, user_id, eat_time, meal_type, food_name, calories,
            protein, fat, carbohydrate, fullness_score, location, note,
            deleted, created_at, updated_at
        ) VALUES (
            #{id}, #{userId}, #{eatTime}, #{mealType}, #{foodName}, #{calories},
            #{protein}, #{fat}, #{carbohydrate}, #{fullnessScore}, #{location}, #{note},
            #{deleted}, NOW(), NOW()
        )
    </insert>

    <!-- 根据ID查询 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM diet_record
        WHERE id = #{id}
        AND deleted = 0
    </select>

    <!-- 根据ID更新 -->
    <update id="updateById" parameterType="diary.common.entity.diet.po.DietRecordPO">
        UPDATE diet_record
        <set>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="eatTime != null">eat_time = #{eatTime},</if>
            <if test="mealType != null">meal_type = #{mealType},</if>
            <if test="foodName != null">food_name = #{foodName},</if>
            <if test="calories != null">calories = #{calories},</if>
            <if test="protein != null">protein = #{protein},</if>
            <if test="fat != null">fat = #{fat},</if>
            <if test="carbohydrate != null">carbohydrate = #{carbohydrate},</if>
            <if test="fullnessScore != null">fullness_score = #{fullnessScore},</if>
            <if test="location != null">location = #{location},</if>
            <if test="note != null">note = #{note},</if>
            <if test="deleted != null">deleted = #{deleted},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据用户ID查询所有未删除的记录 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM diet_record
        WHERE user_id = #{userId}
        AND deleted = 0
        ORDER BY eat_time DESC
    </select>

</mapper>
